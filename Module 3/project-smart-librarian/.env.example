# Required OpenAI credential used by all OpenAI-powered features.
OPENAI_API_KEY=your_openai_api_key

# Core text models.
LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small

# Speech-to-text configuration for voice questions.
STT_MODEL=gpt-4o-mini-transcribe
STT_RESPONSE_FORMAT=text

# Text-to-speech configuration for narrated recommendations.
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_RESPONSE_FORMAT=mp3

# Moderation model used for both input and output safety checks.
MODERATION_MODEL=omni-moderation-latest

# Image generation defaults for cover and scene creation.
IMAGE_MODEL=gpt-image-1-mini
IMAGE_OUTPUT_FORMAT=png
IMAGE_QUALITY=low
IMAGE_STYLE=vivid
IMAGE_COVER_SIZE=1024x1536
IMAGE_SCENE_SIZE=1536x1024

# Local vector store settings.
CHROMA_PATH=chroma_db
COLLECTION_NAME=book_summaries
TOP_K=3

# Guardrail and orchestration limits.
ENABLE_INPUT_FILTER=true
MAX_USER_QUERY_CHARS=500
MAX_TOOL_ROUNDS=3
LOG_LEVEL=INFO
